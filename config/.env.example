# ─────────────────────────────────────────────────────────
# S2 / S2.1 environment variables
# Copy to /home/ubuntu/.openclaw/.env and fill in values.
# ─────────────────────────────────────────────────────────

# ── S2 legacy bots (Bot1–Bot8) ────────────────────────────
S2_BOT1_API_KEY=
S2_BOT1_API_SECRET=
S2_BOT2_API_KEY=
S2_BOT2_API_SECRET=
S2_BOT3_API_KEY=
S2_BOT3_API_SECRET=
S2_BOT4_API_KEY=
S2_BOT4_API_SECRET=
S2_BOT5_API_KEY=
S2_BOT5_API_SECRET=
S2_BOT6_API_KEY=
S2_BOT6_API_SECRET=
S2_BOT7_API_KEY=
S2_BOT7_API_SECRET=
S2_BOT8_API_KEY=
S2_BOT8_API_SECRET=

# ── S2.1 scaled-entry engine — DEEP (Bot9) ────────────────
# Separate $100 sub-account on Bybit. One-way position mode required.
S21_DEEP_API_KEY=
S21_DEEP_API_SECRET=

# ── Shared Bybit config ───────────────────────────────────
# Mainnet: https://api.bybit.com
# Testnet: https://api-demo.bybit.com
BYBIT_BASE_URL=https://api.bybit.com

# ── Portal ────────────────────────────────────────────────
PORTAL_PASSWORD=
PORTAL_HOST=0.0.0.0
PORTAL_PORT=3010

# ── Webhook ───────────────────────────────────────────────
WEBHOOK_SECRET=

# ── Database ─────────────────────────────────────────────
S2_DB_PATH=/tmp/qs2_review/data/s2.sqlite

# ── Telegram — S2.1 alerts (new channel, separate from any S2 channel) ──
# Set before PR 6 ships. If unset, alert calls are silent no-ops.
TELEGRAM_BOT_TOKEN=
TELEGRAM_S21_CHAT_ID=
