# Q_S2 environment variables
# Copy relevant entries to /home/ubuntu/.openclaw/.env on EC2
# This file is documentation only — never commit real secrets

# Bybit API credentials (per-bot — see config/bots.json for botId list)
# BOT1_API_KEY=
# BOT1_API_SECRET=
# BOT2_API_KEY=
# BOT2_API_SECRET=
# ... (Bot3–Bot8 follow the same pattern)

# Webhook authentication
# WEBHOOK_SECRET=

# Runtime paths
# S2_DB_PATH=/home/ubuntu/.openclaw/workspace/Q_S2/data/s2.sqlite
# BYBIT_BASE_URL=https://api.bybit.com

# Portal configuration
# PORTAL_PASSWORD=            # Leave empty for open access (behind tunnel)
# MDX_RENEWAL_DATE=2026-05-25 # MDX subscription renewal — YYYY-MM-DD format
# PORTFOLIO_BASELINE_USDT=2799.94 # Total wallet at last capital reset; update on each top-up
